# COMMIT 01b -- fix(tasks): finish commit 01 (source-time uv warning)
#
# Your manual 0001 covered the rename and the tasks.py header; this
# remaining piece rewords the stale lw warning in tsk.sh, switches the
# check from a hardcoded ~/.local/bin/uv path to command -v uv, and
# sends it to stderr. Apply with git apply (not git am).
#
# VERIFY:
#   git apply 0001b-finish-uv-warning.patch
#   bash -c 'PATH=/usr/bin:/bin source tasks/tsk.sh'  -> tsk-worded warning
#   bash -c 'source tasks/tsk.sh && type tsk >/dev/null && echo silent-ok'
diff --git a/tasks/tsk.sh b/tasks/tsk.sh
index 5297eb8..9ff887c 100644
--- a/tasks/tsk.sh
+++ b/tasks/tsk.sh
@@ -18,8 +18,8 @@ export TASKS_LOCAL_DIR
 # Warn once at source time on the abnormal path; silent when healthy so
 # shell startup stays quiet.
 
-if [ ! -x "$HOME/.local/bin/uv" ]; then
-    echo "lw: warning: uv not found at $HOME/.local/bin/uv. lw alias will not work."
+if ! command -v uv >/dev/null 2>&1; then
+    echo "tsk: warning: uv not found on PATH. tsk command will not work." >&2
 fi
 
 if [ ! -f "$TSK_SCRIPT" ]; then
